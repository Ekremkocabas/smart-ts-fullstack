{
  "expo": {
    "name": "Smart-TS",
    "slug": "smart-ts",
    "owner": "smarttechbv",
    "version": "1.5.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "smartts",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "be.smarttech.smartts",
      "buildNumber": "3",
      "infoPlist": {
        "NSCameraUsageDescription": "Selfie nemen bij handtekening",
        "NSPhotoLibraryUsageDescription": "Foto selecteren voor werkbon",
        "NSLocationWhenInUseUsageDescription": "Locatie ophalen voor werkbon"
      }
    },
    "android": {
      "package": "be.smarttech.smartts",
      "versionCode": 6,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Selfie nemen bij handtekening"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Foto selecteren voor selfie verificatie",
          "cameraPermission": "Selfie nemen bij handtekening verificatie"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Locatie ophalen voor werkbon registratie"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#F5A623"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "apiUrl": "https://web-production-7bce.up.railway.app",
      "eas": {
        "projectId": "9dd093e7-a900-4295-b278-efe5315c1a87"
      }
    }
  }
}

# Smart-TS Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Connection String
# For local development: mongodb://localhost:27017
# For production (MongoDB Atlas): mongodb+srv://username:password@cluster.mongodb.net/werkbon_db
MONGO_URL=mongodb://localhost:27017

# Database Name
DB_NAME=werkbon_db

# Email Service (Resend)
RESEND_API_KEY=your_resend_api_key_here
SENDER_EMAIL=info@smart-techbv.be

# Public app URL used in emails
APP_URL=https://your-app-url.example.com

# Server Configuration (optional, defaults shown)
PORT=8001
